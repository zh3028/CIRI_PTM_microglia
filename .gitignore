# R temporary files
.Rhistory
.RData
.Rproj.user
.Rsession
*.Rproj

# Raw data archives (too large, not tracked)
*.tar
*.tar.gz
*.tgz
*.gz
*.zip

# macOS system files
.DS_Store
._*
.MacOSX
__MACOSX

# Windows system files
Thumbs.db
desktop.ini

# Large processed objects (can be regenerated by scripts)
data/processed/*.rds
data/processed/*.RData

# Temporary files
*.tmp
*.log
*.aux
*.out

# Output files that are generated on-the-fly (optional: keep if you want to share results)
# results/figures/*.pdf   # you may uncomment if you want to commit figures
# results/tables/*.csv    # uncomment if you want to commit tables

# Renv (optional)
renv/library/
renv/staging/
renv/local/
renv/lockfile.R